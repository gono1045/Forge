IDENTIFICATION DIVISION.
PROGRAM-ID. SHOP.

DATA DIVISION.

WORKING-STORAGE SECTION.
01 COMMAND PIC 9 VALUE 1.
01 ITEM-COUNT PIC 9 VALUE 2.
01 I PIC 9.
01 BUY-QTY     PIC 9(5).
01 BUY-QTY-STR PIC X(5).
01 TOTAL-COST  PIC 9(8).

LINKAGE SECTION.
01 LK-MONEY PIC 9(6).
01 LK-HP    PIC S9(4).
01 LK-ITEM.
  05 LK-ITEM-STOCK OCCURS 5 PIC 9(3).
01 LK-ITEM-TABLE.
  05 LK-ITEM-MASTER OCCURS 5.
    10 LK-ITEM-NAME  PIC X(40).
    10 LK-ITEM-PRICE PIC 9(4).
    10 LK-ITEM-HEAL  PIC 9(3).

PROCEDURE DIVISION USING LK-MONEY LK-HP LK-ITEM LK-ITEM-TABLE.

MAIN.
  PERFORM INIT-ITEM
  PERFORM SHOP-LOOP
  GOBACK.

SHOP-LOOP.
  PERFORM UNTIL COMMAND = 0
    DISPLAY "------ ショップ ------"
    DISPLAY "所持金：" LK-MONEY
    DISPLAY "HP：" LK-HP

    PERFORM VARYING I FROM 1 UNTIL I > ITEM-COUNT
      DISPLAY I "：" FUNCTION TRIM(LK-ITEM-NAME(I)) "(" LK-ITEM-PRICE(I) "G)"
    END-PERFORM

    DISPLAY "0：ショップを出る"

    ACCEPT COMMAND

    EVALUATE COMMAND
      WHEN 0
        DISPLAY "ショップを出た"
      WHEN 1 THRU ITEM-COUNT
        PERFORM BUY-ITEM
      WHEN OTHER
        DISPLAY "無効なコマンド"
    END-EVALUATE
  END-PERFORM

  GOBACK.

BUY-ITEM.
  MOVE 0 TO BUY-QTY
  MOVE SPACES TO BUY-QTY-STR

  PERFORM UNTIL BUY-QTY > 0
    DISPLAY FUNCTION TRIM(LK-ITEM-NAME(COMMAND)) "をいくつ購入しますか？"
    DISPLAY "価格：" LK-ITEM-PRICE(COMMAND) "G/個"
    DISPLAY "所持金：" LK-MONEY "G"
    DISPLAY "キャンセルする場合は0を入力してください"
    ACCEPT BUY-QTY-STR

    IF FUNCTION TRIM(BUY-QTY-STR) IS NOT NUMERIC
      DISPLAY "数字を入力してください"
      MOVE 0 TO BUY-QTY
    ELSE
      MOVE FUNCTION TRIM(BUY-QTY-STR) TO BUY-QTY

      IF BUY-QTY = 0
        DISPLAY "キャンセルしました"
        EXIT PARAGRAPH
      END-IF

      IF BUY-QTY <= 0
        DISPLAY "1以上の数を入力してください"
        MOVE 0 TO BUY-QTY
      END-IF
    END-IF
  END-PERFORM

  *> 合計金額計算
  COMPUTE TOTAL-COST = BUY-QTY * LK-ITEM-PRICE(COMMAND)

  IF LK-MONEY >= TOTAL-COST
    SUBTRACT TOTAL-COST FROM LK-MONEY
    ADD BUY-QTY TO LK-ITEM-STOCK(COMMAND)

    DISPLAY FUNCTION TRIM(LK-ITEM-NAME(COMMAND))
      "を" BUY-QTY "個購入した"
    DISPLAY "所持金：" LK-MONEY "G"
  ELSE
    DISPLAY "お金が足りない"
  END-IF.

INIT-ITEM.
  PERFORM VARYING I FROM 1 UNTIL I > 5
    MOVE SPACES TO LK-ITEM-NAME(I)
    MOVE 0 TO LK-ITEM-PRICE(I)
    MOVE 0 TO LK-ITEM-HEAL(I)
  END-PERFORM

  MOVE "ポーション" TO LK-ITEM-NAME(1)
  MOVE 100 TO LK-ITEM-PRICE(1)
  MOVE 30 TO LK-ITEM-HEAL(1)

  MOVE "ハイポーション" TO LK-ITEM-NAME(2)
  MOVE 300 TO LK-ITEM-PRICE(2)
  MOVE 80 TO LK-ITEM-HEAL(2).
